rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /dailyViews/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /portfolioProjects/{id} {
      allow read: if resource.data.active == true || request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    match /softwareSolutions/{id} {
      allow read: if resource.data.active == true || request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    match /blogPosts/{postId} {
      allow read: if resource.data.active == true || request.auth != null;
      allow create, update, delete: if request.auth != null;

      match /comments/{commentId} {
        function blogPostDoc() {
          return get(/databases/$(database)/documents/blogPosts/$(postId));
        }
        allow read: if blogPostDoc().data.active == true || request.auth != null;
        allow create: if blogPostDoc().data.active == true
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && (!request.resource.data.keys().hasAny(['authorName'])
              || (request.resource.data.authorName is string
                  && request.resource.data.authorName.size() <= 80));
        allow delete: if request.auth != null;
        allow update: if false;
      }

      match /ratings/{ratingId} {
        function blogPostDocRating() {
          return get(/databases/$(database)/documents/blogPosts/$(postId));
        }
        allow read: if blogPostDocRating().data.active == true || request.auth != null;
        allow create: if blogPostDocRating().data.active == true
          && request.resource.data.stars is int
          && request.resource.data.stars >= 1
          && request.resource.data.stars <= 5;
        allow delete: if request.auth != null;
        allow update: if false;
      }
    }

    match /surveys/{surveyId} {
      allow get: if resource.data.active == true || request.auth != null;
      allow list: if request.auth != null;
      allow create, update, delete: if request.auth != null;

      match /responses/{responseId} {
        allow create: if get(/databases/$(database)/documents/surveys/$(surveyId)).data.active == true;
        allow read: if request.auth != null;
        allow update, delete: if request.auth != null;
      }
    }
  }
}
